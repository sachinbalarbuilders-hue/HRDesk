@page
@model AttendanceUI.Pages.Loans.Applications.DetailsModel

@{
    ViewData["Title"] = "Loan Details";
    var loan = Model.LoanApplication;
    var statusClass = (loan.Status == "Approved" || loan.Status == "Active") ? "text-bg-success" :
                      loan.Status == "Completed" ? "text-bg-secondary" :
                      loan.Status == "Rejected" ? "text-bg-danger" :
                      loan.Status == "Cancelled" ? "text-bg-secondary" : "text-bg-warning";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="mb-1 fw-bold">Loan Application Details</h4>
        <p class="text-muted mb-0 small">
            @if (!string.IsNullOrEmpty(loan.ApplicationNumber))
            {
                <code>@loan.ApplicationNumber</code>
                <text> — </text>
            }
            @loan.Employee?.EmployeeName
        </p>
    </div>
    <div class="d-flex gap-2 align-items-center">
        <span class="badge @statusClass fs-6">@loan.Status.ToUpper()</span>
        <a asp-page="./Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<div class="row g-4">
    <!-- Application Info -->
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-file-text me-2 text-primary"></i>Application Info</h5>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5 text-muted">Employee</dt>
                    <dd class="col-sm-7 fw-semibold">@loan.Employee?.EmployeeName</dd>

                    <dt class="col-sm-5 text-muted">Loan Type</dt>
                    <dd class="col-sm-7"><span class="badge text-bg-secondary">@loan.LoanType?.TypeName</span></dd>

                    <dt class="col-sm-5 text-muted">Loan Amount</dt>
                    <dd class="col-sm-7 fw-bold">₹@loan.LoanAmount.ToString("N0")</dd>

                    <dt class="col-sm-5 text-muted">Installments</dt>
                    <dd class="col-sm-7">@loan.Installments months</dd>

                    <dt class="col-sm-5 text-muted">Per Month</dt>
                    <dd class="col-sm-7">₹@loan.InstallmentAmount.ToString("N0")</dd>

                    <dt class="col-sm-5 text-muted">Start Date</dt>
                    <dd class="col-sm-7">@loan.StartDate.ToString("dd MMM yyyy")</dd>

                    <dt class="col-sm-5 text-muted">Status</dt>
                    <dd class="col-sm-7"><span class="badge @statusClass">@loan.Status.ToUpper()</span></dd>

                    @if (loan.Status == "Active" || loan.Status == "Completed")
                    {
                        var amountPaid = loan.LoanAmount - loan.RemainingAmount;
                        <dt class="col-sm-5 text-muted">Paid</dt>
                        <dd class="col-sm-7 text-success fw-semibold">₹@amountPaid.ToString("N0")</dd>

                        <dt class="col-sm-5 text-muted">Remaining</dt>
                        <dd class="col-sm-7">₹@loan.RemainingAmount.ToString("N0") (@loan.RemainingInstallments mo left)</dd>
                    }

                    <dt class="col-sm-5 text-muted">Reason</dt>
                    <dd class="col-sm-7 text-muted small">@loan.Reason</dd>

                    @if (!string.IsNullOrEmpty(loan.ForeclosureRemark))
                    {
                        <dt class="col-sm-5 text-muted">Foreclosure Remark</dt>
                        <dd class="col-sm-7 text-danger small fw-semibold">@loan.ForeclosureRemark</dd>
                    }

                    @if (!string.IsNullOrEmpty(loan.ApprovedBy))
                    {
                        <dt class="col-sm-5 text-muted">Approved By</dt>
                        <dd class="col-sm-7">@loan.ApprovedBy</dd>

                        <dt class="col-sm-5 text-muted">Approved On</dt>
                        <dd class="col-sm-7">@loan.ApprovedDate?.ToString("dd MMM yyyy HH:mm")</dd>
                    }
                </dl>

                @if (loan.Status == "Pending")
                {
                    <hr />
                    <div class="d-flex gap-2">
                        <form method="post" asp-page-handler="Approve" asp-route-id="@loan.Id">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-success" onclick="return confirm('Approve this loan?')">
                                <i class="bi bi-check-lg me-1"></i>Approve
                            </button>
                        </form>
                        <form method="post" asp-page-handler="Reject" asp-route-id="@loan.Id">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger" onclick="return confirm('Reject this loan?')">
                                <i class="bi bi-x-lg me-1"></i>Reject
                            </button>
                        </form>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Installment Schedule -->
    <div class="col-md-6">
        @if (Model.Installments.Any())
        {
            <div class="card h-100">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <h5 class="mb-0"><i class="bi bi-calendar-check me-2 text-success"></i>Installment Schedule</h5>
                    <span class="badge text-bg-secondary">@Model.Installments.Count installments</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-modern align-middle mb-0">
                            <thead>
                                <tr>
                                    <th class="ps-3">#</th>
                                    <th>Due Month</th>
                                    <th>Amount</th>
                                    <th>Status</th>
                                    <th>Paid Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var inst in Model.Installments)
                                {
                                    var instClass = inst.Status == "Paid" ? "text-bg-success" :
                                                    inst.Status == "Settled" ? "text-bg-primary" :
                                                    inst.Status == "Partial" ? "text-bg-warning" : "text-bg-secondary";
                                    <tr>
                                        <td class="ps-3 text-muted">@inst.InstallmentNumber</td>
                                        <td>@inst.DueMonth</td>
                                        <td>₹@inst.Amount.ToString("N0")</td>
                                        <td><span class="badge @instClass">@inst.Status.ToUpper()</span></td>
                                        <td class="small text-muted">
                                            @(inst.PaidDate.HasValue ? inst.PaidDate.Value.ToString("dd MMM yyyy") : "—")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div class="mt-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
        <a asp-page="./Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back to List
        </a>
    </div>
    <div class="d-flex gap-2">
        @if (loan.Status == "Active")
        {
            <!-- Foreclose Loan Button -->
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#forecloseModal">
                <i class="bi bi-shield-check me-1 text-white"></i>Foreclose Loan
            </button>

            <!-- Foreclose Modal -->
            <div class="modal fade" id="forecloseModal" tabindex="-1" aria-labelledby="forecloseModalLabel" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content text-start">
                        <form method="post" asp-page-handler="Foreclose" asp-route-id="@loan.Id">
                            @Html.AntiForgeryToken()
                            <div class="modal-header">
                                <h5 class="modal-title" id="forecloseModalLabel">Foreclose Loan</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body">
                                <p class="text-danger fw-bold mb-3 small">
                                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                    Settling remaining installments and closing the loan balance.
                                </p>

                                @if (Model.HasCurrentMonthPending)
                                {
                                    <div class="mb-3 p-3 bg-light rounded border shadow-sm">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" asp-for="IncludeCurrentMonth" id="includeCurrentToggle" 
                                                   onchange="updateForeclosureSummary()">
                                            <label class="form-check-label fw-bold small text-primary" for="includeCurrentToggle">
                                                Include @Model.CurrentMonthName installment?
                                            </label>
                                        </div>
                                        <div class="form-text extra-small mt-1">
                                            Uncheck this if you want the upcoming payroll to deduct the @Model.CurrentMonthName EMI automatically.
                                        </div>
                                    </div>
                                }

                                <div class="card bg-soft-primary border-0 mb-3">
                                    <div class="card-body p-3">
                                        <div class="d-flex justify-content-between align-items-center mb-1">
                                            <span class="small text-muted">Total to Settle:</span>
                                            <span class="fw-bold text-primary" id="foreclosureTotalDisplay">₹@Model.TotalPendingAmount.ToString("N2")</span>
                                        </div>
                                        <div class="extra-small text-muted" id="foreclosureDetailsDisplay">
                                            Settle all remaining @Model.PendingInstallmentsCount installments.
                                        </div>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="ForeclosureRemark" class="form-label fw-bold small">Foreclosure Remark</label>
                                    <textarea asp-for="ForeclosureRemark" class="form-control" rows="3" placeholder="e.g., Full payment received via cheque #1234..." required></textarea>
                                    <div class="form-text small">Please provide a valid remark for legal records.</div>
                                </div>
                            </div>
                            <div class="modal-footer bg-light">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-primary px-4 shadow-sm">
                                    Confirm Foreclosure
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            @section Scripts {
                <script>
                    function updateForeclosureSummary() {
                        const includeCurrent = document.getElementById('includeCurrentToggle').checked;
                        const hasCurrent = @Model.HasCurrentMonthPending.ToString().ToLower();
                        const currentAmount = @Model.CurrentMonthAmount;
                        const totalAmount = @Model.TotalPendingAmount;
                        const totalCount = @Model.PendingInstallmentsCount;

                        let finalAmount = totalAmount;
                        let finalCount = totalCount;

                        if (hasCurrent && !includeCurrent) {
                            finalAmount -= currentAmount;
                            finalCount -= 1;
                        }

                        document.getElementById('foreclosureTotalDisplay').innerText = '₹' + finalAmount.toLocaleString('en-IN', { minimumFractionDigits: 2 });
                        document.getElementById('foreclosureDetailsDisplay').innerText = `Settle ${finalCount} installments.`;
                    }
                    
                    // Run once on load if toggle exists
                    if (document.getElementById('includeCurrentToggle')) {
                        updateForeclosureSummary();
                    }
                </script>
            }
        }
        <form method="post" asp-page-handler="Delete" asp-route-id="@loan.Id"
              onsubmit="return confirm('Delete this loan application? This also removes all pending installments.');">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-danger">
                <i class="bi bi-trash me-1"></i>Delete Application
            </button>
        </form>
    </div>
</div>
