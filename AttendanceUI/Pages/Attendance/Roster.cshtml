@page
@model AttendanceUI.Pages.Attendance.RosterModel
@{
    ViewData["Title"] = "Shift Roster";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="mb-1 fw-bold">Shift Roster</h4>
        <p class="text-muted mb-0 small">Daily shift assignments and schedule management</p>
    </div>
    <div class="d-flex gap-2 align-items-center">
        <form method="get" class="d-flex gap-2 align-items-center me-2">
            <input type="hidden" name="StartDate" value="@Model.StartDate?.ToString("yyyy-MM-dd")" />
            <div class="input-group input-group-sm shadow-sm" style="width: 250px;">
                <span class="input-group-text bg-white border-end-0"><i class="bi bi-search"></i></span>
                <input type="text" name="SearchQuery" class="form-control border-start-0" placeholder="Search employee..." value="@Model.SearchQuery">
            </div>
            <select name="DeptId" class="form-select form-select-sm shadow-sm" style="width: 180px;" onchange="this.form.submit()">
                <option value="">All Departments</option>
                @foreach (var dept in Model.Departments)
                {
                    <option value="@dept.Id" selected="@(Model.DeptId == dept.Id)">@dept.DepartmentName</option>
                }
            </select>
            @if (!string.IsNullOrEmpty(Model.SearchQuery) || Model.DeptId.HasValue)
            {
                <a asp-page="./Roster" asp-route-StartDate="@Model.StartDate?.ToString("yyyy-MM-dd")" class="btn btn-sm btn-outline-secondary shadow-sm" title="Clear filters">
                    <i class="bi bi-x-lg"></i>
                </a>
            }
            <button type="submit" class="btn btn-sm btn-dark shadow-sm">Filter</button>
        </form>

        <button type="button" class="btn btn-primary shadow-sm" data-bs-toggle="modal" data-bs-target="#generateModal">
            <i class="bi bi-magic me-1"></i>Shift Generate
        </button>
        <div class="btn-group shadow-sm">
            <a asp-page="./Roster" asp-route-StartDate="@Model.StartDate?.AddDays(-7).ToString("yyyy-MM-dd")" asp-route-SearchQuery="@Model.SearchQuery" asp-route-DeptId="@Model.DeptId" class="btn btn-light" title="Previous Week">
                <i class="bi bi-chevron-left"></i>
            </a>
            <a asp-page="./Roster" asp-route-StartDate="" asp-route-SearchQuery="@Model.SearchQuery" asp-route-DeptId="@Model.DeptId" class="btn btn-light" title="Current Week">
                Today
            </a>
            <span class="btn btn-white fw-bold disabled">@Model.StartDate?.ToString("dd/MM/yyyy") - @Model.EndDate.ToString("dd/MM/yyyy")</span>
            <a asp-page="./Roster" asp-route-StartDate="@Model.StartDate?.AddDays(7).ToString("yyyy-MM-dd")" asp-route-SearchQuery="@Model.SearchQuery" asp-route-DeptId="@Model.DeptId" class="btn btn-light" title="Next Week">
                <i class="bi bi-chevron-right"></i>
            </a>
        </div>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4 border-0 shadow-sm" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm border-0 overflow-hidden">
    <div class="card-body p-0">
        <div class="table-responsive roster-container" style="max-height: 700px;">
            <table class="table table-bordered mb-0 align-middle">
                <thead class="table-light sticky-top bg-white shadow-sm" style="z-index: 10;">
                    <tr>
                        <th class="ps-4 sticky-col bg-light" style="min-width: 250px;">Employee</th>
                        @for (int i = 0; i < 7; i++)
                        {
                            var date = Model.StartDate?.AddDays(i);
                            <th class="text-center @(date == DateOnly.FromDateTime(DateTime.Now) ? "bg-primary-subtle" : "")">
                                <div class="small fw-normal">@date?.DayOfWeek</div>
                                <div class="fw-bold">@date?.ToString("dd/MM/yyyy")</div>
                            </th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var emp in Model.Employees)
                    {
                        <tr>
                            <td class="ps-4 sticky-col bg-white border-end shadow-sm">
                                <div class="d-flex align-items-center">
                                    <div class="avatar-sm bg-primary-subtle text-primary rounded-circle me-3 d-flex align-items-center justify-content-center fw-bold">
                                        @emp.EmployeeName.Substring(0, Math.Min(2, emp.EmployeeName.Length)).ToUpper()
                                    </div>
                                    <div>
                                        <div class="fw-bold mb-0">
                                            @emp.EmployeeName
                                        </div>
                                        <div class="text-muted small">@emp.Department?.DepartmentName</div>
                                    </div>
                                </div>
                            </td>
                            @for (int i = 0; i < 7; i++)
                            {
                                var date = Model.StartDate.Value.AddDays(i);
                                var entry = Model.RosterEntries.FirstOrDefault(r => r.EmployeeId == emp.EmployeeId && r.RosterDate == date);
                                <td class="p-1 text-center roster-cell" 
                                    data-emp-id="@emp.EmployeeId" 
                                    data-date="@date.ToString("yyyy-MM-dd")"
                                    data-current-shift="@entry?.ShiftId"
                                    data-is-weekoff="@(entry?.IsWeekOff ?? false)">
                                    
                                    @{
                                        var leave = Model.LeaveApplications.FirstOrDefault(l => l.EmployeeId == emp.EmployeeId && date >= l.StartDate && date <= l.EndDate);
                                        var attRecord = Model.DailyAttendanceRecords.FirstOrDefault(a => a.EmployeeId == emp.EmployeeId && a.RecordDate == date);
                                        bool isSandwichLeave = attRecord != null && !string.IsNullOrWhiteSpace(attRecord.Status) && 
                                                               (attRecord.Status.Contains("PL") || attRecord.Status.Contains("SL") || attRecord.Status.Contains("CL") || attRecord.Status.Contains("EL"));
                                    }

                                    @if (leave != null || isSandwichLeave)
                                    {
                                        var leaveLabel = leave?.LeaveType?.Code ?? attRecord?.Status ?? "Leave";
                                        var dayType = leave?.DayType ?? "Full Day";
                                        
                                        <div class="p-3 bg-warning-subtle border border-warning text-warning-emphasis rounded small cursor-pointer shadow-sm" onclick="editCell(this)">
                                            <div class="fw-bold">On Leave</div>
                                            <div class="small" style="font-size: 0.7rem;">@leaveLabel (@dayType)</div>
                                        </div>
                                    }
                                    else if (entry == null)
                                    {
                                        <div class="p-3 border border-dashed rounded text-muted small cursor-pointer hover-bg-light" onclick="editCell(this)">
                                            Not Set
                                        </div>
                                    }
                                    else if (entry.IsWeekOff)
                                    {
                                        <div class="p-3 bg-light border rounded text-secondary small cursor-pointer fw-bold shadow-sm" style="border-style: dashed !important;" onclick="editCell(this)">
                                            Week Off
                                        </div>
                                    }
                                    else
                                    {
                                        var bgColor = entry.Shift?.ColorCode ?? "#4e73df";
                                        
                                        <div class="p-3 text-white rounded small cursor-pointer shadow-sm" style="background-color: @bgColor; border: 1px solid @bgColor;" onclick="editCell(this)">
                                            <div class="fw-bold text-truncate" title="@entry.Shift?.ShiftName">@entry.Shift?.ShiftName</div>
                                            <div class="small" style="font-size: 0.75rem; opacity: 0.9;">@entry.Shift?.StartTime.ToString("hh:mm tt") - @entry.Shift?.EndTime.ToString("hh:mm tt")</div>
                                        </div>
                                    }
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    @if (Model.TotalPages > 1)
    {
        <div class="card-footer bg-white border-top py-3">
            <div class="d-flex align-items-center justify-content-between">
                <div class="text-muted small">
                    Showing <span class="fw-bold">@(((Model.PageNum - 1) * Model.PageSize) + 1)</span> to <span class="fw-bold">@(Math.Min(Model.PageNum * Model.PageSize, Model.TotalCount))</span> of <span class="fw-bold">@Model.TotalCount</span> employees
                </div>
                <nav aria-label="Page navigation">
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(Model.PageNum <= 1 ? "disabled" : "")">
                            <a class="page-link" asp-page="./Roster" asp-route-PageNum="@(Model.PageNum - 1)" asp-route-StartDate="@Model.StartDate?.ToString("yyyy-MM-dd")" asp-route-SearchQuery="@Model.SearchQuery" asp-route-DeptId="@Model.DeptId">Previous</a>
                        </li>
                        
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            if (i == 1 || i == Model.TotalPages || (i >= Model.PageNum - 2 && i <= Model.PageNum + 2))
                            {
                                <li class="page-item @(i == Model.PageNum ? "active" : "")">
                                    <a class="page-link" asp-page="./Roster" asp-route-PageNum="@i" asp-route-StartDate="@Model.StartDate?.ToString("yyyy-MM-dd")" asp-route-SearchQuery="@Model.SearchQuery" asp-route-DeptId="@Model.DeptId">@i</a>
                                </li>
                            }
                            else if (i == 2 || (i == Model.TotalPages - 1 && Model.TotalPages > 5))
                            {
                                <li class="page-item disabled"><span class="page-link">...</span></li>
                            }
                        }

                        <li class="page-item @(Model.PageNum >= Model.TotalPages ? "disabled" : "")">
                            <a class="page-link" asp-page="./Roster" asp-route-PageNum="@(Model.PageNum + 1)" asp-route-StartDate="@Model.StartDate?.ToString("yyyy-MM-dd")" asp-route-SearchQuery="@Model.SearchQuery" asp-route-DeptId="@Model.DeptId">Next</a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    }
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content shadow-lg border-0">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-bold" id="modalTitle">Edit Shift</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editEmpId" />
                <input type="hidden" id="editDate" />
                
                <div class="mb-3">
                    <label class="form-label small fw-bold">Select Shift</label>
                    <select id="editShiftId" class="form-select shadow-sm">
                        <option value="">-- No Shift --</option>
                        @foreach (var s in Model.Shifts)
                        {
                            <option value="@s.Id">@s.ShiftName (@s.StartTime.ToString("hh:mm tt"))</option>
                        }
                    </select>
                </div>
                
                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" id="editIsWeekOff">
                    <label class="form-check-label fw-bold small" for="editIsWeekOff">Mark as Week Off</label>
                </div>
                
                <button type="button" class="btn btn-primary w-100 shadow-sm" onclick="saveCell()">
                    <i class="bi bi-save me-1"></i>Save Change
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Bulk Generate Modal -->
<div class="modal fade" id="generateModal" tabindex="-1">
    <div class="modal-dialog">
        <form method="post" asp-page-handler="Generate">
            <div class="modal-content shadow-lg border-0">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold">Shift Generate</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted small">Select a date range and optionally a specific employee to automatically assign default shifts and week-offs.</p>
                    <div class="row g-4">
                        <!-- Row 1: Shift Type -->
                        <div class="col-md-12">
                            <label class="form-label fw-bold small text-muted mb-1">Shift Type <span class="text-danger">*</span></label>
                            <select name="newShiftId" id="generateShiftId" class="form-select shadow-sm" onchange="toggleMasterShiftOption()">
                                <option value="">Select Shift Type...</option>
                                @foreach (var s in Model.Shifts)
                                {
                                    <option value="@s.Id">@s.ShiftName (@s.StartTime.ToString("hh:mm tt"))</option>
                                }
                            </select>
                            <div class="form-text small">Leave empty to use each employee's current master shift.</div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-muted mb-1">Department</label>
                            <select id="filterDepartment" class="form-select shadow-sm" onchange="filterEmployeesByDept()">
                                <option value="">Select Department...</option>
                                @foreach (var dept in Model.Employees.Select(e => e.Department?.DepartmentName).Where(d => d != null).Distinct().OrderBy(d => d))
                                {
                                    <option value="@dept">@dept</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-muted mb-1">Employee <span class="text-danger">*</span></label>
                            <div class="dropdown w-100" id="employeeDropdown">
                                <button class="btn btn-outline-secondary w-100 text-start dropdown-toggle shadow-sm d-flex justify-content-between align-items-center" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <span id="selectedEmployeesLabel">Select Employee</span>
                                </button>
                                <div class="dropdown-menu w-100 p-2 shadow-lg" style="max-height: 250px; overflow-y: auto;">
                                    <div class="px-2 mb-2 d-flex justify-content-between border-bottom pb-2">
                                        <button type="button" class="btn btn-link btn-sm p-0 text-decoration-none" onclick="toggleAllCheckboxes(true)">Select All</button>
                                        <button type="button" class="btn btn-link btn-sm p-0 text-decoration-none text-danger" onclick="toggleAllCheckboxes(false)">Clear</button>
                                    </div>
                                    @foreach (var emp in Model.Employees.OrderBy(e => e.EmployeeName))
                                    {
                                        <div class="form-check px-4 py-1 emp-item" data-dept="@(emp.Department?.DepartmentName ?? "")">
                                            <input class="form-check-input employee-checkbox" type="checkbox" name="employeeIds" value="@emp.EmployeeId" id="emp_@emp.EmployeeId" onchange="updateSelectedLabel()">
                                            <label class="form-check-label small w-100" for="emp_@emp.EmployeeId">
                                                @emp.EmployeeName
                                            </label>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- Options: Update Master and Overwrite -->
                        <div class="col-md-12">
                            <div class="p-3 border rounded bg-light">
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <div class="form-check form-switch mt-1">
                                            <input class="form-check-input" type="checkbox" name="updateMasterShift" id="updateMasterShift" value="true">
                                            <label class="form-check-label fw-bold small" for="updateMasterShift">Update Master Shift permanently?</label>
                                        </div>
                                    </div>
                                    <div class="col-md-6 border-start">
                                        <div class="form-check form-switch mt-1">
                                            <input class="form-check-input" type="checkbox" name="overwrite" id="overwriteEntries" value="true">
                                            <label class="form-check-label fw-bold text-danger small" for="overwriteEntries">Overwrite existing entries?</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Date Range -->
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-muted mb-1">From Date</label>
                            <input type="date" name="fromDate" class="form-control shadow-sm" required value="@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-muted mb-1">To Date</label>
                            <input type="date" name="toDate" class="form-control shadow-sm" required value="@DateTime.Now.AddMonths(1).AddDays(-DateTime.Now.Day).ToString("yyyy-MM-dd")" />
                        </div>
                </div>
                <div class="modal-footer border-top-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4">Generate Roster</button>
                </div>
            </div>
        </form>
    </div>
</div>

<style>
    .roster-container { border-radius: 8px; }
    .sticky-col { position: sticky; left: 0; z-index: 5; border-right: 1px solid #dee2e6; }
    .roster-cell { transition: all 0.2s; min-width: 140px; }
    .hover-bg-light:hover { background-color: #f8f9fa; cursor: pointer; }
    .cursor-pointer { cursor: pointer; }
    .avatar-sm { width: 38px; height: 38px; font-size: 0.8rem; }
    .btn-white { background-color: white; border: 1px solid #dee2e6; }
</style>

@section Scripts {
    <script>
        const editModal = new bootstrap.Modal(document.getElementById('editModal'));

        function editCell(element) {
            const td = element.closest('.roster-cell');
            const empId = td.dataset.empId;
            const date = td.dataset.date; // yyyy-mm-dd
            const shiftId = td.dataset.currentShift;
            const isWeekoff = td.dataset.isWeekoff === 'True';

            document.getElementById('editEmpId').value = empId;
            document.getElementById('editDate').value = date;
            document.getElementById('editShiftId').value = shiftId || "";
            document.getElementById('editIsWeekOff').checked = isWeekoff;
            
            // Format date for title (yyyy-mm-dd to dd/mm/yyyy)
            const parts = date.split('-');
            const displayDate = `${parts[2]}/${parts[1]}/${parts[0]}`;
            document.getElementById('modalTitle').innerText = 'Shift for ' + displayDate;
            
            editModal.show();
        }

        async function saveCell() {
            const empId = document.getElementById('editEmpId').value;
            const dateStr = document.getElementById('editDate').value;
            const shiftId = document.getElementById('editShiftId').value;
            const isWeekOff = document.getElementById('editIsWeekOff').checked;

            const formData = new FormData();
            formData.append('empId', empId);
            formData.append('dateStr', dateStr);
            if (shiftId) formData.append('shiftId', shiftId);
            formData.append('isWeekOff', isWeekOff);

            const response = await fetch('?handler=UpdateCell', {
                method: 'POST',
                body: formData,
                headers: {
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                }
            });

            if (response.ok) {
                location.reload();
            } else {
                alert('Error saving roster change.');
            }
        }

        function filterEmployeesByDept() {
            const dept = document.getElementById('filterDepartment').value;
            const items = document.querySelectorAll('.emp-item');
            
            items.forEach(item => {
                if (!dept || item.dataset.dept === dept) {
                    item.classList.remove('d-none');
                } else {
                    item.classList.add('d-none');
                    // Optional: Uncheck if hidden? Better not to uncheck in case they want cross-dept
                }
            });
        }

        function toggleAllCheckboxes(checked) {
            const visibleCheckboxes = document.querySelectorAll('.emp-item:not(.d-none) .employee-checkbox');
            visibleCheckboxes.forEach(cb => cb.checked = checked);
            updateSelectedLabel();
        }

        function updateSelectedLabel() {
            const checkedBoxes = document.querySelectorAll('.employee-checkbox:checked');
            const label = document.getElementById('selectedEmployeesLabel');
            
            if (checkedBoxes.length === 0) {
                label.innerText = 'Select Employee';
            } else if (checkedBoxes.length === 1) {
                const empName = checkedBoxes[0].nextElementSibling.innerText.trim();
                label.innerText = empName;
            } else {
                label.innerText = checkedBoxes.length + ' Employees Selected';
            }
        }

        function toggleMasterShiftOption() {
            // Logic handled by being always visible or specific checks
        }

        // Prevent dropdown from closing when clicking inside the employee selection
        document.addEventListener('DOMContentLoaded', function () {
            const dropdown = document.querySelector('#employeeDropdown .dropdown-menu');
            if (dropdown) {
                dropdown.addEventListener('click', function (e) {
                    e.stopPropagation();
                });
            }
        });
    </script>
}
