@page
@model AttendanceUI.Pages.Attendance.RosterModel
@{
    ViewData["Title"] = "Shift Roster";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="mb-1 fw-bold">Shift Roster</h4>
        <p class="text-muted mb-0 small">Daily shift assignments and schedule management</p>
    </div>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#generateModal">
            <i class="bi bi-magic me-1"></i>Bulk Generate
        </button>
        <div class="btn-group shadow-sm">
            <a asp-page="./Roster" asp-route-StartDate="@Model.StartDate?.AddDays(-7).ToString("yyyy-MM-dd")" class="btn btn-light" title="Previous Week">
                <i class="bi bi-chevron-left"></i>
            </a>
            <a asp-page="./Roster" asp-route-StartDate="" class="btn btn-light" title="Current Week">
                Today
            </a>
            <span class="btn btn-white fw-bold disabled">@Model.StartDate?.ToString("dd/MM/yyyy") - @Model.EndDate.ToString("dd/MM/yyyy")</span>
            <a asp-page="./Roster" asp-route-StartDate="@Model.StartDate?.AddDays(7).ToString("yyyy-MM-dd")" class="btn btn-light" title="Next Week">
                <i class="bi bi-chevron-right"></i>
            </a>
        </div>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4 border-0 shadow-sm" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm border-0 overflow-hidden">
    <div class="card-body p-0">
        <div class="table-responsive roster-container" style="max-height: 700px;">
            <table class="table table-bordered mb-0 align-middle">
                <thead class="table-light sticky-top bg-white shadow-sm" style="z-index: 10;">
                    <tr>
                        <th class="ps-4 sticky-col bg-light" style="min-width: 250px;">Employee</th>
                        @for (int i = 0; i < 7; i++)
                        {
                            var date = Model.StartDate?.AddDays(i);
                            <th class="text-center @(date == DateOnly.FromDateTime(DateTime.Now) ? "bg-primary-subtle" : "")">
                                <div class="small fw-normal">@date?.DayOfWeek</div>
                                <div class="fw-bold">@date?.ToString("dd/MM/yyyy")</div>
                            </th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var emp in Model.Employees)
                    {
                        <tr>
                            <td class="ps-4 sticky-col bg-white border-end shadow-sm">
                                <div class="d-flex align-items-center">
                                    <div class="avatar-sm bg-primary-subtle text-primary rounded-circle me-3 d-flex align-items-center justify-content-center fw-bold">
                                        @emp.EmployeeName.Substring(0, Math.Min(2, emp.EmployeeName.Length)).ToUpper()
                                    </div>
                                    <div>
                                        <div class="fw-bold mb-0">@emp.EmployeeName</div>
                                        <div class="text-muted small">@emp.Department?.DepartmentName</div>
                                    </div>
                                </div>
                            </td>
                            @for (int i = 0; i < 7; i++)
                            {
                                var date = Model.StartDate.Value.AddDays(i);
                                var entry = Model.RosterEntries.FirstOrDefault(r => r.EmployeeId == emp.EmployeeId && r.RosterDate == date);
                                <td class="p-1 text-center roster-cell" 
                                    data-emp-id="@emp.EmployeeId" 
                                    data-date="@date.ToString("yyyy-MM-dd")"
                                    data-current-shift="@entry?.ShiftId"
                                    data-is-weekoff="@(entry?.IsWeekOff ?? false)">
                                    
                                    @{
                                        var leave = Model.LeaveApplications.FirstOrDefault(l => l.EmployeeId == emp.EmployeeId && date >= l.StartDate && date <= l.EndDate);
                                        var attRecord = Model.DailyAttendanceRecords.FirstOrDefault(a => a.EmployeeId == emp.EmployeeId && a.RecordDate == date);
                                        bool isSandwichLeave = attRecord != null && !string.IsNullOrWhiteSpace(attRecord.Status) && 
                                                               (attRecord.Status.Contains("PL") || attRecord.Status.Contains("SL") || attRecord.Status.Contains("CL") || attRecord.Status.Contains("EL"));
                                    }

                                    @if (leave != null || isSandwichLeave)
                                    {
                                        var leaveLabel = leave?.LeaveType?.Code ?? attRecord?.Status ?? "Leave";
                                        var dayType = leave?.DayType ?? "Full Day";
                                        
                                        <div class="p-3 bg-warning-subtle border border-warning text-warning-emphasis rounded small cursor-pointer shadow-sm" onclick="editCell(this)">
                                            <div class="fw-bold">On Leave</div>
                                            <div class="small" style="font-size: 0.7rem;">@leaveLabel (@dayType)</div>
                                        </div>
                                    }
                                    else if (entry == null)
                                    {
                                        <div class="p-3 border border-dashed rounded text-muted small cursor-pointer hover-bg-light" onclick="editCell(this)">
                                            Not Set
                                        </div>
                                    }
                                    else if (entry.IsWeekOff)
                                    {
                                        <div class="p-3 bg-light border rounded text-secondary small cursor-pointer fw-bold shadow-sm" style="border-style: dashed !important;" onclick="editCell(this)">
                                            Week Off
                                        </div>
                                    }
                                    else
                                    {
                                        var bgColor = entry.Shift?.ColorCode ?? "#4e73df";
                                        
                                        <div class="p-3 text-white rounded small cursor-pointer shadow-sm" style="background-color: @bgColor; border: 1px solid @bgColor;" onclick="editCell(this)">
                                            <div class="fw-bold text-truncate" title="@entry.Shift?.ShiftName">@entry.Shift?.ShiftName</div>
                                            <div class="small" style="font-size: 0.75rem; opacity: 0.9;">@entry.Shift?.StartTime.ToString("hh:mm tt") - @entry.Shift?.EndTime.ToString("hh:mm tt")</div>
                                        </div>
                                    }
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content shadow-lg border-0">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-bold" id="modalTitle">Edit Shift</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editEmpId" />
                <input type="hidden" id="editDate" />
                
                <div class="mb-3">
                    <label class="form-label small fw-bold">Select Shift</label>
                    <select id="editShiftId" class="form-select shadow-sm">
                        <option value="">-- No Shift --</option>
                        @foreach (var s in Model.Shifts)
                        {
                            <option value="@s.Id">@s.ShiftName (@s.StartTime.ToString("hh:mm tt"))</option>
                        }
                    </select>
                </div>
                
                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" id="editIsWeekOff">
                    <label class="form-check-label fw-bold small" for="editIsWeekOff">Mark as Week Off</label>
                </div>
                
                <button type="button" class="btn btn-primary w-100 shadow-sm" onclick="saveCell()">
                    <i class="bi bi-save me-1"></i>Save Change
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Bulk Generate Modal -->
<div class="modal fade" id="generateModal" tabindex="-1">
    <div class="modal-dialog">
        <form method="post" asp-page-handler="Generate">
            <div class="modal-content shadow-lg border-0">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold">Bulk Roster Generation</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted small">Select a date range and optionally a specific employee to automatically assign default shifts and week-offs.</p>
                    <div class="row g-3">
                        <div class="col-md-12 mb-2">
                            <label class="form-label fw-bold">Select Employee (Optional)</label>
                            <select name="employeeId" class="form-select border-primary shadow-sm">
                                <option value="">-- All Active Employees --</option>
                                @foreach (var emp in Model.Employees)
                                {
                                    <option value="@emp.EmployeeId">@emp.EmployeeName (@emp.EmployeeId)</option>
                                }
                            </select>
                            <div class="form-text small text-muted">Leave as "All Active Employees" to generate for everyone.</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">From Date</label>
                            <input type="date" name="fromDate" class="form-control" required value="@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">To Date</label>
                            <input type="date" name="toDate" class="form-control" required value="@DateTime.Now.AddMonths(1).AddDays(-DateTime.Now.Day).ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="col-md-12">
                            <div class="form-check p-3 border rounded bg-light mt-2">
                                <input class="form-check-input ms-0 me-2" type="checkbox" name="overwrite" id="overwriteEntries" value="true">
                                <label class="form-check-label fw-bold text-danger" for="overwriteEntries">
                                    Overwrite existing entries?
                                </label>
                                <div class="text-muted small ms-4">If checked, this will reset all scheduled shifts to match the current employee settings.</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4">Generate Roster</button>
                </div>
            </div>
        </form>
    </div>
</div>

<style>
    .roster-container { border-radius: 8px; }
    .sticky-col { position: sticky; left: 0; z-index: 5; border-right: 1px solid #dee2e6; }
    .roster-cell { transition: all 0.2s; min-width: 140px; }
    .hover-bg-light:hover { background-color: #f8f9fa; cursor: pointer; }
    .cursor-pointer { cursor: pointer; }
    .avatar-sm { width: 38px; height: 38px; font-size: 0.8rem; }
    .btn-white { background-color: white; border: 1px solid #dee2e6; }
</style>

@section Scripts {
    <script>
        const editModal = new bootstrap.Modal(document.getElementById('editModal'));

        function editCell(element) {
            const td = element.closest('.roster-cell');
            const empId = td.dataset.empId;
            const date = td.dataset.date; // yyyy-mm-dd
            const shiftId = td.dataset.currentShift;
            const isWeekoff = td.dataset.isWeekoff === 'True';

            document.getElementById('editEmpId').value = empId;
            document.getElementById('editDate').value = date;
            document.getElementById('editShiftId').value = shiftId || "";
            document.getElementById('editIsWeekOff').checked = isWeekoff;
            
            // Format date for title (yyyy-mm-dd to dd/mm/yyyy)
            const parts = date.split('-');
            const displayDate = `${parts[2]}/${parts[1]}/${parts[0]}`;
            document.getElementById('modalTitle').innerText = 'Shift for ' + displayDate;
            
            editModal.show();
        }

        async function saveCell() {
            const empId = document.getElementById('editEmpId').value;
            const dateStr = document.getElementById('editDate').value;
            const shiftId = document.getElementById('editShiftId').value;
            const isWeekOff = document.getElementById('editIsWeekOff').checked;

            const formData = new FormData();
            formData.append('empId', empId);
            formData.append('dateStr', dateStr);
            if (shiftId) formData.append('shiftId', shiftId);
            formData.append('isWeekOff', isWeekOff);

            const response = await fetch('?handler=UpdateCell', {
                method: 'POST',
                body: formData,
                headers: {
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                }
            });

            if (response.ok) {
                location.reload();
            } else {
                alert('Error saving roster change.');
            }
        }
    </script>
}
