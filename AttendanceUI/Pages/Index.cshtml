@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="row g-4 mb-4">
    <!-- Total Employees -->
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card card-stat h-100">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <span class="text-muted fw-semibold">Total Employees</span>
                    <div class="stat-icon bg-soft-primary">
                        <i class="bi bi-people"></i>
                    </div>
                </div>
                <h2 class="mb-1 fw-bold text-dark">@Model.TotalEmployees</h2>
                <small class="text-success"><i class="bi bi-arrow-up-short"></i> Active</small>
            </div>
        </div>
    </div>

    <!-- Present Today -->
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card card-stat h-100">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <span class="text-muted fw-semibold">Present Today</span>
                    <div class="stat-icon bg-soft-success">
                        <i class="bi bi-check-circle"></i>
                    </div>
                </div>
                <h2 class="mb-1 fw-bold text-dark">@Model.PresentToday</h2>
                <small class="text-muted">@DateTime.Now.ToString("dd MMM yyyy")</small>
            </div>
        </div>
    </div>

    <!-- Pending Leaves -->
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card card-stat h-100">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <span class="text-muted fw-semibold">Pending Leaves</span>
                    <div class="stat-icon bg-soft-warning">
                        <i class="bi bi-calendar-minus"></i>
                    </div>
                </div>
                <h2 class="mb-1 fw-bold text-dark">@Model.PendingLeaves</h2>
                <a asp-page="/Leaves/Applications/Index" class="small text-primary text-decoration-none stretched-link">Review Requests <i class="bi bi-arrow-right"></i></a>
            </div>
        </div>
    </div>

    <!-- Pending Regularizations -->
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card card-stat h-100">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <span class="text-muted fw-semibold">Regularizations</span>
                    <div class="stat-icon bg-soft-secondary">
                        <i class="bi bi-clock-history"></i>
                    </div>
                </div>
                <h2 class="mb-1 fw-bold text-dark">@Model.PendingRegularizations</h2>
                <a asp-page="/Regularizations/Index" class="small text-primary text-decoration-none stretched-link">Action Needed <i class="bi bi-arrow-right"></i></a>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom-0 pt-4 px-4 pb-0 d-flex align-items-center justify-content-between">
                <div>
                    <h5 class="fw-bold mb-1 text-dark"><i class="bi bi-broadcast me-2 text-primary"></i>Machine Connectivity Status</h5>
                    <p class="text-muted small mb-0">Monitor real-time health and last synchronization of biometric devices</p>
                </div>
                <div class="text-end">
                    <span class="badge rounded-pill bg-light text-muted border py-2 px-3">
                        <i class="bi bi-clock-history me-1"></i> Auto-updates every sync
                    </span>
                </div>
            </div>
            <div class="card-body p-4">
                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
                    @foreach (var machine in Model.MachineStatuses)
                    {
                        <div class="col">
                            <div class="p-3 border rounded-3 device-card bg-light bg-opacity-10">
                                <div class="d-flex align-items-center justify-content-between mb-2">
                                    <div class="d-flex align-items-center">
                                        <span class="status-indicator @machine.StatusClass" id="indicator-@machine.Id"></span>
                                        <span class="fw-bold text-dark">@machine.Name</span>
                                    </div>
                                    <button type="button" class="btn btn-sm btn-link text-primary p-0 text-decoration-none" 
                                            onclick="checkMachineStatus(@machine.Id, this)" title="Verify Connection">
                                        <i class="bi bi-arrow-clockwise"></i> Verify
                                    </button>
                                </div>
                                <div class="small text-muted mb-1">
                                    <i class="bi bi-pc-display me-1"></i> IP: @machine.IpAddress
                                </div>
                                <div class="sync-time-text @(machine.LastSync.HasValue ? "" : "text-danger")" id="sync-@machine.Id">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span><i class="bi bi-cloud-check me-1"></i> 
                                        @if (machine.LastSync.HasValue)
                                        {
                                            var diff = DateTime.Now - machine.LastSync.Value;
                                            if (diff.TotalMinutes < 1) { <span>Just now</span> }
                                            else if (diff.TotalMinutes < 60) { <span>@( (int)diff.TotalMinutes) min ago</span> }
                                            else if (diff.TotalHours < 24) { <span>@( (int)diff.TotalHours) hours ago</span> }
                                            else { <span>@machine.LastSync.Value.ToString("dd MMM, hh:mm tt")</span> }
                                        }
                                        else
                                        {
                                            <span>Never synchronized</span>
                                        }
                                        </span>
                                        @if (machine.RecordsSynced > 0)
                                        {
                                            <span class="badge bg-soft-info text-info small">@machine.RecordsSynced records</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex align-items-center justify-content-between">
                <h5 class="mb-0">Quick Actions</h5>
            </div>
            <div class="card-body">
                <div class="d-flex gap-3 flex-wrap">
                    <a asp-page="/Attendance/Process" class="btn btn-outline-primary">
                        <i class="bi bi-gear me-2"></i> Process Attendance
                    </a>
                    <a asp-page="/Payroll/Process" class="btn btn-outline-success">
                        <i class="bi bi-cash-stack me-2"></i> Process Payroll
                    </a>
                    <a asp-page="/Employees/Index" class="btn btn-outline-secondary">
                        <i class="bi bi-person-plus me-2"></i> Manage Employees
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function checkMachineStatus(id, btn, silent = false) {
            const icon = btn.querySelector('i');
            const indicator = document.getElementById(`indicator-${id}`);
            
            if (icon) icon.classList.add('bi-spin');
            if (btn) btn.disabled = true;

            try {
                const response = await fetch(`?handler=CheckConnection&id=${id}`);
                const result = await response.json();
                
                if (result.success) {
                    indicator.className = 'status-indicator status-online status-pulse';
                    if (!silent) alert(`Success: ${result.message}`);
                } else {
                    indicator.className = 'status-indicator status-offline';
                    if (!silent) alert(`Failed: ${result.message}`);
                }
            } catch (error) {
                console.error('Error checking status:', error);
                if (!silent) alert('An error occurred while checking connection.');
            } finally {
                if (icon) icon.classList.remove('bi-spin');
                if (btn) btn.disabled = false;
            }
        }

        // Auto-check on load
        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('[onclick^="checkMachineStatus"]').forEach(btn => {
                const onclick = btn.getAttribute('onclick');
                const id = onclick.match(/\d+/)[0];
                checkMachineStatus(id, btn, true);
            });
        });
    </script>
    <style>
        @@keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
        .bi-spin {
            display: inline-block;
            animation: spin 1s linear infinite;
        }
    </style>
}
